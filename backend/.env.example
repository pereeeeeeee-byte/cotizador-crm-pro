# ======================================================================
# COTIZADOR CRM PRO - Backend Environment Variables
# Copia este archivo como .env y completa los valores reales.
# ======================================================================

NODE_ENV=development
PORT=4000

# Base de datos PostgreSQL
DATABASE_URL="postgresql://crm_user:crm_password@localhost:5432/cotizador_crm_pro?schema=public"

# JWT
JWT_ACCESS_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-access"
JWT_REFRESH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Frontend URL (para links de verificación, recuperación de password, CORS)
FRONTEND_URL="http://localhost:5173"

# Correo (SMTP) - usado para verificación de email y recuperación de contraseña
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="usuario@example.com"
SMTP_PASS="password"
SMTP_FROM="Quotia <no-reply@example.com>"

# Almacenamiento de archivos (logos, firmas, PDFs)
# "local" = guarda en disco del contenedor (NO recomendado en Railway/Render:
#           el disco se reinicia en cada despliegue, perderías los archivos).
# "cloudinary" = recomendado para producción gratuita. Crea una cuenta gratis
#                en https://cloudinary.com (25GB gratis) y completa las 3
#                variables CLOUDINARY_* más abajo.
STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH="./uploads"
PUBLIC_FILES_BASE_URL="http://localhost:4000/uploads"

# AWS S3 (driver no implementado aún — usa cloudinary o local por ahora)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Cloudinary (si STORAGE_DRIVER=cloudinary) - https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# OpenAI (módulo IA de cotizaciones)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
